# Copy this file to .env and fill in the values.
# All environment variables for the entire monorepo live here.

# Android SDK path (for Expo development)
ANDROID_HOME=

# Prisma — PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/moventis-lleida"

# Google Maps JavaScript API key + Map ID (required for AdvancedMarker)
NEXT_PUBLIC_MAPS_API_KEY=""
NEXT_PUBLIC_MAPS_MAP_ID=""
