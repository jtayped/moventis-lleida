generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Route {
    id         String @id @default(cuid())
    externalId String @unique

    name  String
    code  String
    color String

    // Aggregated route geometry derived from principal outbound variants.
    // Shape: { paths: [lng, lat][][] }. Null until first scraper run.
    path Json?

    stops         Stop[]
    variants      RouteVariant[]
    operatingDays OperatingDay[]

    updatedAt DateTime  @updatedAt
    createdAt DateTime  @default(now())
    deletedAt DateTime?
}

model RouteVariant {
    id      String @id @default(cuid())
    routeId String
    route   Route  @relation(fields: [routeId], references: [id], onDelete: Cascade)

    // Primary trayecto ID (ID_TRAYECTO_CONCAT or last element of ID_TRAYECTO).
    externalId  Int
    // All Moventis trayecto segment IDs — each maps to one GetKMLs call.
    trayectoIds Int[]

    description String
    direction   String  // "I" = outbound (ida), "V" = return (vuelta)
    isPrincipal Boolean

    // Per-variant route geometry. Shape: { paths: [lng, lat][][] }
    geometry Json?

    stops RouteVariantStop[]

    updatedAt DateTime @updatedAt
    createdAt DateTime @default(now())

    @@unique([routeId, externalId])
    @@index([routeId])
}

model RouteVariantStop {
    id        String       @id @default(cuid())
    variantId String
    variant   RouteVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
    stopId    String
    stop      Stop         @relation(fields: [stopId], references: [id], onDelete: Cascade)
    sequence  Int

    @@unique([variantId, sequence])
    @@index([variantId])
    @@index([stopId])
}

model OperatingDay {
    date DateTime @db.Date

    routeId String
    route   Route  @relation(fields: [routeId], references: [id], onDelete: Cascade)

    @@id([routeId, date])
    @@index([date])
}

model Stop {
    id         String @id @default(cuid())
    externalId String @unique

    name String

    latitude  Float
    longitude Float

    routes       Route[]
    variantStops RouteVariantStop[]

    updatedAt DateTime  @updatedAt
    createdAt DateTime  @default(now())
    deletedAt DateTime?
}
